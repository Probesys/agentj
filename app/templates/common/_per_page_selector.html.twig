<nav>
    <ul class="pagination">
        {% for per_page in per_pages %}
            <li class="page-item {% if app.session.get('perPage') == per_page %}active{% endif %}">
                <a
                    title="{{'Generics.actions.showNbItemPerPage'|trans({'%nbItems%': per_page})}}"
                    class="page-link"
                    href="{{ path('per_page', {'nbItems': per_page}) }}"
                >
                    {{ per_page }}
                </a>
            </li>
        {% endfor %}
    </ul>
</nav>
