{% extends 'base.html.twig' %}

{% block title %}
	{{ 'Entities.Group.labels.usersGroup'|trans() }}
	"
	{{group.name}}
	"
{% endblock %}

{% block body %}

	{% set _title = 'Entities.Group.labels.usersGroup'|trans ~ ' : ' ~ group.name %}
	{% embed 'common/blockTitleAndButtons.html.twig' %}{% endembed %}

	<div class="col mb-3 bg-white pb-3">
		<div class="row">
			<div class="col-md-12">
				{% include 'common/_rapidSearchForm.html.twig'%}
			</div>
		</div>
	</div>
	<div class="table-responsive">
		<section id="no-more-tables">
			<table id="table_users_group" class="table">
				<thead>
					<tr>
						<th>
                            {{ knp_pagination_sortable(users, 'Entities.Group.Name'|trans(), 'u.fullname') }}
						</th>
						<th>
                            {{ knp_pagination_sortable(users, 'Entities.User.fields.email'|trans(), 'u.email') }}
						</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					{% for user in users %}
						<tr>
							<td data-title="{{'Entities.Group.Name'|trans }}">
								{{user.fullname}}
							</td>
							<td data-title="{{'Entities.User.fields.email'|trans }}">
								{{user.email}}
								{% if user.getOriginalUser  %}
									<span class="badge badge-info">
										Alias
									</span>
								{% endif %}
							</td>
							<td>
								{# Don't remove alias directly, remove original user #}
								{% if not user.getOriginalUser  %}
									<ul class="list-inline list-unstyled">
										<li class="list-inline-item">
                                            <form
                                                method="post"
                                                action="{{ path('group_remove_user',{'id' : group.id,'user' : user.id}) }}"
                                                data-turbo-confirm="{{ 'Message.Dialogs.confirmRemoveUserFromGroupContent'|trans }}"
                                            >
                                            <input
                                                type="hidden"
                                                name="_token"
                                                value="{{ csrf_token('removeUser' ~ user.id) }}"
                                            >
											<button
                                                type="submit"
                                                class='btn btn-sm btn-danger confirmModal'
                                                title="{{ 'Message.Dialogs.confirmRemoveUserFromGroupTitle'|trans() }}"
                                            >
												<i class="fas fa-trash-alt d-none d-md-block d-lg-none"></i>
												<span class="d-md-none d-lg-block">
													{{ 'Entities.Group.Actions.Delete'|trans() }}
												</span>
											</button>
                                            </form>
										</li>
									</ul>
								{% endif %}
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</section>
	</div>

    {% include 'common/_paginationAndPerPageSelector.html.twig' with { 'pagination': users } %}

	<div class="d-flex justify-content-center">
		<a class="btn btn-outline-secondary" href="{{ path('groups_index') }}">
			{{ 'Entities.Group.Actions.backToGroupList'|trans() }}
		</a>
	</div>

{% endblock %}
