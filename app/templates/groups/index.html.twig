{% extends 'base.html.twig' %}

{% block title %}
	{{ 'Entities.Group.Title'|trans() }}
{% endblock %}

{% block body %}
	{% set _title = 'Entities.Group.Title'|trans ~ ' : ' ~ groups.getTotalItemCount %}
	{% embed 'common/blockTitleAndButtons.html.twig' %}

		{% block content_button_actions %}
			<a href="#" data-url-modal-content="{{ path('groups_new') }}" class="btn-open-modal btn btn-success float-right col-sm-12 col-md-4">
				<i class="fas fa-plus"></i>&nbsp;{{ 'Entities.Group.Actions.New'|trans() }}</a>
		{% endblock %}

	{% endembed %}

	<div class="col mb-3 bg-white pb-3">
		<div class="row">
			<div class="col-md-12">
				{% include 'common/_rapidSearchForm.html.twig'%}
			</div>
		</div>
	</div>

	<div class="table-responsive">
		<section id="no-more-tables">
			<table id="table_groups" class="table">
				<thead>
					<tr>
						<th>{{ knp_pagination_sortable(groups, 'Entities.Group.Name'|trans(), 'g.name') }}</th>
						<th>{{ knp_pagination_sortable(groups, 'Entities.Domain.Name'|trans(), 'd.domain') }}</th>
						<th>{{ knp_pagination_sortable(groups, 'Generics.fields.priority'|trans(), 'g.priority') }}</th>
						<th>{{ knp_pagination_sortable(groups, 'Generics.fields.active'|trans(), 'g.active') }}</th>
						<th>{{ knp_pagination_sortable(groups, 'Entities.Group.Updated'|trans(), 'g.datemod') }}</th>
						<th>{{ 'Entities.Group.Actions.list'|trans() }}</th>
					</tr>
				</thead>
				<tbody>
					{% for group in groups %}
						<tr>
							{#          <td><input type="checkbox"></td>#}
							<td data-title="{{'Entities.Group.Name'|trans }}">{{group.name}}</td>
							<td data-title="{{'Entities.Domain.Name'|trans }}">{{group.domain.domain}}</td>
							<td data-title="{{'Generics.fields.priority'|trans }}">{{ group.priority }}</td>
							<td data-title="{{'Generics.fields.active'|trans }}">{{ group.active ? 'Generics.labels.yes'|trans  :  'Generics.labels.no'|trans }}</td>
							<td data-title="{{'Entities.Group.Updated'|trans }}">{{group.datemod | format_datetime('short', 'short') }}</td>
							<td>
								<ul class="list-inline list-unstyled">
									<li class="list-inline-item">
										<a
											href="#"
											data-url-modal-content="{{ path('groups_edit',{'id':group.id}) }}"
											class='btn-open-modal btn btn-sm btn-success'
											data-target='authorized'
											title="{{ 'Entities.Group.Actions.updateGroup'|trans() }}"
                                        >
											<i class="fas fa-edit  d-none d-md-block d-lg-none"></i>
											<span class="d-md-none d-lg-block">{{ 'Entities.Group.Actions.Updated'|trans() }}</span>
										</a>
									</li>
									<li class="list-inline-item">
										<a
											href="{{ path('groups_wblist_index',{'groupId':group.id}) }}"
											class='btn btn-sm btn-dark '
											data-target='authorized'
											title="{{ 'Entities.Group.labels.grouprules'|trans() }}"
                                        >
											<i class="fas fa-ruler d-none d-md-block d-lg-none"></i>
											<span class="d-md-none d-lg-block">{{ 'Entities.Group.labels.rules'|trans() }}</span>
										</a>
									</li>
									<li class="list-inline-item">
										<a
											href="{{ path('groups_list_users',{'id':group.id}) }}"
											class='btn btn-sm btn-secondary'
											data-target='authorized'
											title="{{ 'Entities.Group.Actions.updateGroup'|trans() }}"
                                        >
											<i class="fas fa-edit  d-none d-md-block d-lg-none"></i>
											<span class="d-md-none d-lg-block">{{ 'Entities.Group.labels.usersGroup'|trans() }}</span>
										</a>
									</li>
									<li class="list-inline-item">
										<form
											method="post"
											class="d-inline"
											action="{{ path('groups_delete', {'id': group.id}) }}"
											data-turbo-confirm="{{ 'Message.Dialogs.confirmDeleteGroupContent'|trans }}"
                                        >
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ group.id) }}">
											<button type="submit" class="btn btn-sm btn-danger">
												<i class="fas fa-trash-alt d-xsd-sm-block d-sm-block d-md-block d-lg-none"></i>
												<span class="d-none d-lg-block">
													{{ 'Entities.Group.Actions.Delete'|trans() }}
												</span>
											</button>
										</form>

									</li>
								</ul>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</section>
	</div>
	{% include 'common/_paginationAndPerPageSelector.html.twig' with { 'pagination': groups } %}
	{% include 'alertsPopup.html.twig' %}


{% endblock %}
