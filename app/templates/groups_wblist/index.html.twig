{% extends 'base.html.twig' %}

{% block title %}
	{{ 'Entities.Group.labels.grouprules'|trans() }}
	{{group.name}}
{% endblock %}

{% block body %}

	{% set _title = 'Entities.Group.labels.grouprules'|trans ~ ' : ' ~ group.name %}
	{% embed 'common/blockTitleAndButtons.html.twig' %}

		{% block content_button_actions %}
			<a href="#" data-url-modal-content="{{ path('groups_edit',{'id':group.id}) }}" class=' btn-open-modal btn-success btn float-right ml-1 col-sm-12 col-md-4 mb-1' data-target='authorized'>{{ 'Entities.Group.Actions.updateGroup'|trans() }}</a>
			<a href="#" data-modal-method-type="GET" data-url-modal-content="{{ path('groups_wblist_new',{'groupId':group.id}) }}" class="btn-open-modal btn btn-success float-right col-sm-12 col-md-4">
				<i class="fas fa-plus"></i>&nbsp;{{ 'Entities.Group.Actions.addRule'|trans() }}
			</a>

		{% endblock %}

	{% endembed %}


	<div class="col mb-3 bg-white pb-3">
		<div class="row">
			<div class="col-md-12">
				{% include 'common/_rapidSearchForm.html.twig'%}
			</div>
		</div>
	</div>

	<div class="table-responsive">
		<section id="no-more-tables">
			<table class="table">
				<thead>
					<tr>
						<th>{{ knp_pagination_sortable(groups_wblists, 'Generics.fields.sender'|trans(), 'madr.email') }}</th>
						<th>{{ 'Entities.Group.labels.rules'|trans() }}</th>
						<th>{{ 'Generics.labels.actions'|trans() }}</th>
					</tr>
				</thead>
				<tbody>
					{% for groups_wblist in groups_wblists %}
						{% set email = groups_wblist.getMailaddr().email %}
						{% if  email != "@." %}
							<tr>
								<td data-title="{{'Generics.fields.sender'|trans }}">{{email}}</td>
								<td data-title="{{'Entities.Group.labels.rules'|trans }}">
									{{ groups_wblist.wbRuleName | trans }}
								</td>
								<td>
									<ul class="list-inline list-unstyled">
										<li class="list-inline-item">
											<a
                                                href="#"
                                                data-modal-method-type="GET"
                                                data-url-modal-content="{{ path('groups_wblist_edit',{'sid':groups_wblist.mailaddr.id,'groupId':groups_wblist.groups.id,}) }}"
                                                class='btn-open-modal btn btn-sm btn-success '
                                                title="{{ 'Entities.Group.Actions.updateGroup'|trans() }}"
                                            >
												<i class="fas fa-edit  d-none d-md-block d-lg-none"></i>
												<span class="d-md-none d-lg-block">{{ 'Entities.Group.Actions.Updated'|trans() }}</span>
											</a>
										</li>
										<li class="list-inline-item">
											<form
                                                method="post"
                                                action="{{ path('groups_wblist_delete',{'groupId':groups_wblist.groups.id,'sid':groups_wblist.mailaddr.id}) }}"
                                                data-turbo-confirm="{{ 'Message.Dialogs.confirmRemoveRuleContent'|trans }}"
                                            >
                                                <input
                                                    type="hidden"
                                                    name="_token"
                                                    value="{{ csrf_token('delete' ~ groups_wblist.groups.id ~ '_' ~ groups_wblist.mailaddr.id) }}"
                                                >
												<button
                                                    type="submit"
                                                    class='btn btn-sm btn-danger confirmModal'
                                                    title="{{ 'Entities.Group.Actions.deleteRule'|trans() }}"
                                                >
													<i class="fas fa-trash-alt d-none d-md-block d-lg-none"></i>
													<span class="d-md-none d-lg-block">{{ 'Entities.Group.Actions.deleteRule'|trans() }}</span>
												</button>
											</form>
										</li>
									</ul>
								</td>
							</tr>
						{% endif %}
					{% endfor %}
				</tbody>
			</table>
		</section>
	</div>

	{% include 'common/_paginationAndPerPageSelector.html.twig' with { 'pagination': groups_wblists } %}
	{% include 'alertsPopup.html.twig' %}

	<div class="d-flex justify-content-center pb-3">
		<a class="btn btn-outline-secondary" href="{{ path('groups_index') }}">{{ 'Entities.Group.Actions.backToGroupList'|trans() }}</a>

	</div>

{% endblock %}
