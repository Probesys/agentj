{% extends 'base.html.twig' %}

{% block title %}{{'Entities.User.indexLocal'|trans}}{% endblock %}

{% block body %}

    {% set _title = 'Entities.User.indexLocal'|trans ~ ' : ' ~ users.getTotalItemCount%}
    {% embed 'common/blockTitleAndButtons.html.twig' %}

        {% block content_button_actions %}
            <a data-url-modal-content="{{ path('user_local_new') }}"  href="#" class="btn-open-modal btn btn-success float-right col-sm-12 col-md-4"><i class="fas fa-plus"></i>&nbsp;{{ 'Entities.User.actions.add_new'|trans() }}</a>
        {% endblock %}

    {% endembed %}

{% include 'common/_batchActionsAndSearch.html.twig'
    with {
        'actionPath': path('user_email_batch_delete'),
        'csrfToken': csrf_token('delete user'),
        'messageConfirm': 'Message.Actions.massiveActionContent'|trans,
        'buttonLabel': 'Generics.actions.deleteSelection'|trans
        }
%}

 <div class="table-responsive">
    <section id="no-more-tables">
        <table class="table">
            <thead>
                <tr>
                    <th>
                        <input type="checkbox" class="cb" id="checkAll" data-target-checkall-class="selected-msg">
                        <label class="for-cb check-all" for="checkAll"></label>
                    </th>
                    <th>{{ knp_pagination_sortable(users, 'Entities.User.fields.userName'|trans, 'u.username') }}</th>
                    <th>{{ knp_pagination_sortable(users, 'Entities.User.fields.fullName'|trans, 'u.fullname') }}</th>
                    <th>{{ knp_pagination_sortable(users, 'Entities.User.fields.roles'|trans, 'u.roles') }}</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>
                            <input type="checkbox" name="id[]" value="{{ user.id }}" id="user_{{ user.id }}" class="cb selected-msg">
                            <label class="for-cb"></label>
                        </td>
                        <td data-title="{{'Entities.User.fields.userName'|trans }}">{{ user.username }}</td>
                        <td data-title="{{'Entities.User.fields.fullName'|trans }}">{{ user.fullname }}</td>
                        <td data-title="{{'Entities.User.fields.roles'|trans }}">
                            {{ user.roles | join(', ') }}
                        </td>
                        <td>
                            <ul class="list-inline list-unstyled">
                                <li class="list-inline-item">
                                    <a href="#" data-url-modal-content="{{ path('user_local_edit', {'id': user.id}) }}" class='btn-open-modal btn btn-sm btn-success' title="{{ 'Generics.actions.edit'|trans() }}">
                                        <i class="fas fa-edit d-none d-md-block d-lg-none"></i>
                                        <span class="d-md-none d-lg-block">{{ 'Generics.actions.edit'|trans() }}</span>
                                    </a>

                                    <a href="#" data-url-modal-content="{{ path('user_local_change_password', {'id': user.id}) }}" class='btn-open-modal btn btn-sm btn-warning' title="{{ 'Generics.actions.changePassword'|trans() }}">
                                        <i class="fas fa-edit d-none d-md-block d-lg-none"></i>
                                        <span class="d-md-none d-lg-block">{{ 'Generics.actions.changePassword'|trans() }}</span>
                                    </a>

                                    {% include 'user/_delete_form.html.twig' with {'user': user} %}

                                    {% if user.email is not null %}
                                        {% include 'user/_impersonation_form.html.twig' with {'user': user} %}
                                    {% endif %}

                                </li>
                            </ul>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
 </div>
    <div class="container-fluid">
        <div class="row">
            <div class="col">
                {{ knp_pagination_render(users) }}
            </div>

            <div class="col">
                {% include 'common/_per_page_selector.html.twig' %}
            </div>
        </div>
    </div>
{% endblock %}
